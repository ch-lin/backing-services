# =============================================================================
# This file contains environment variables for configuring the Docker Compose setup.
# It should not be committed to version control if it contains sensitive data.
# Instead, create a .env.example file with placeholder values.
# =============================================================================

# =============================================================================
# Host Path Mappings (Volumes)
# =============================================================================
# Specifies the directory on the host machine to store the S3 object data.
# This ensures that your files persist even if the container is removed.
S3_DATA_PATH=/volume1/docker/backing-services/s3/data

# =============================================================================
# S3 Root Credentials
# =============================================================================
# The root administrator credentials for S3 (equivalent to AWS Root Access Key).
# These are used to initialize the server and create the default buckets and users.
S3_ROOT_USER=admin
S3_ROOT_PASSWORD=SuperSecretPassword123!

# =============================================================================
# S3 Service Account Credentials
# =============================================================================
# These credentials are used by the backend service to access S3 securely.
# They are automatically generated and populated by the init-secrets.sh script.
S3_SVC_ACCESS_KEY=youtube-hub-backend
S3_SVC_SECRET_KEY=

# =============================================================================
# S3 Application Settings
# =============================================================================
# The default bucket name to be created automatically during initialization.
DEFAULT_BUCKET_NAME=youtube-thumbnails

# =========================================================
# 🟢 Optional
# The default value is defined in docker-compose.yml.
# =========================================================

# =============================================================================
# Service Ports
# =============================================================================
# Defines the external ports on the host machine that map to the internal ports
# of the S3 containers.
# 9000 is the API Port (for S3 protocol communication)
# 9001 is the Web UI Console Port (for browser management)
# S3_API_PORT=9000
# S3_CONSOLE_PORT=9001
