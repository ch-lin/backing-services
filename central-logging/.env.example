# =============================================================================
# This file contains environment variables for configuring the Docker Compose setup.
# It should not be committed to version control if it contains sensitive data.
# Instead, create a .env.example file with placeholder values.
# =============================================================================

# =============================================================================
# Host Path Mappings (Volumes)
# =============================================================================
# Specifies the directory on the host machine to store the logging database data.
# This ensures that your logs persist even if the container is removed.
LOGGING_DB_DATA_PATH="/volume1/docker/Logging Data"

# =============================================================================
# MySQL Root Credentials
# =============================================================================
# The root administrator password for the logging database.
MYSQL_ROOT_PASSWORD=SuperSecretRootPassword123!

# =============================================================================
# MySQL Application Credentials
# =============================================================================
# These credentials are used by the microservices (via Logback) to write logs securely.
MYSQL_USER=logger
MYSQL_PASSWORD=SuperSecretLoggerPassword123!

# =========================================================
# 🟢 Optional
# The default value is defined in docker-compose-logging.yml.
# =========================================================

# =============================================================================
# Service Ports
# =============================================================================
# Defines the external port on the host machine that maps to the internal port
# of the MySQL container. Uncomment and use this if you need external access 
# (e.g., via DBeaver or DataGrip) to query the logs.
# LOGGING_DB_PORT=3309
